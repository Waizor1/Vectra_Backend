# Base
TESTMODE=FALSE
LOG_LEVEL=INFO
TRIAL_DAYS=10
TRIAL_LTE_LIMIT_GB=1.0
ANALYTICS_PAID_INTERVAL_SECONDS=3600
ANALYTICS_TRIAL_INTERVAL_SECONDS=1800
ANALYTICS_REMNAWAVE_TIMEOUT_SECONDS=30
TRIAL_ABUSE_WARNING_GB=3.0
TRIAL_ABUSE_CRITICAL_GB=10.0
TRIAL_ABUSE_SPIKE_SHARE_PCT=50.0
TRIAL_ABUSE_SPIKE_MIN_GB=2.0
# Clean staging/dev only: create DB schema from current models without Aerich migrations.
# Keep false/empty for production databases.
SCHEMA_INIT_GENERATE_ONLY=false

# Compose DB authority (shared by Postgres + Directus + bloobcat)
# POSTGRES_USER is intentionally fixed to `postgres` in docker-compose.yml.
# Required: set POSTGRES_PASSWORD (compose fails fast when missing/empty).
POSTGRES_PASSWORD=change-me

# Telegram
TELEGRAM_TOKEN=123456:telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=change-me
# Set false for staging/web-only environments where this API must not mutate the bot menu/webhook.
TELEGRAM_WEBHOOK_ENABLED=true
# Keep false for blue/green deploys; deleting webhook on app shutdown can race a new instance.
TELEGRAM_DELETE_WEBHOOK_ON_SHUTDOWN=false
# Optional static bot username for staging/web-only environments where Bot API calls are disabled/unavailable.
TELEGRAM_USERNAME=your_bot
TELEGRAM_MINIAPP_URL=https://example.com/
TELEGRAM_WEBAPP_URL=https://t.me/your_bot/your_app/
TELEGRAM_LOGS_CHANNEL=
# Optional: comma-separated IPv4/IPv6 addresses for Bot API fallback when
# api.telegram.org resolves to an unreachable IP on the current VPS/provider.
# Example: TELEGRAM_API_FALLBACK_IPS=149.154.167.220
TELEGRAM_API_FALLBACK_IPS=
# Optional: redirect target after YooKassa payment (use t.me deep link to reopen Telegram).
# Recommended (bot chat): https://t.me/your_bot
# Optional (open Mini App check screen): https://t.me/your_bot/your_app?startapp=payment_check
TELEGRAM_PAYMENT_RETURN_URL=

# YooKassa rollback only. Leave empty when Platega is the active provider.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# Payments
# platega (default/main) or yookassa for manual rollback.
PAYMENT_PROVIDER=platega
# disabled for Platega manual-only; yookassa only when rolling back YooKassa autopay intentionally.
PAYMENT_AUTO_RENEWAL_MODE=disabled

# Platega
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET_KEY=
PLATEGA_BASE_URL=https://app.platega.io
# Optional: set Platega payment method ID (for example 2 for SBP QR) to use
# /transaction/process. Leave empty to let payer select the method via /v2/transaction/process.
PLATEGA_PAYMENT_METHOD=

# RemnaWave
# Must be Vectra-owned. Do not reuse Strata RemnaWave domains
# (`pan.stratavpn.com`, `sub.stratavpn.com`) or Strata squad UUIDs.
REMNAWAVE_URL=https://pan.vectra-pro.net
REMNAWAVE_TOKEN=
# Leave UUIDs empty until Vectra's own RemnaWave squads are created.
REMNAWAVE_DEFAULT_INTERNAL_SQUAD_UUID=
REMNAWAVE_DEFAULT_EXTERNAL_SQUAD_UUID=
REMNAWAVE_LTE_INTERNAL_SQUAD_UUID=
REMNAWAVE_LTE_NODE_MARKER=CHTF

# Script / API
# For docker-compose use host "bloobcat_db"
# In docker-compose bloobcat SCRIPT_DB is derived from POSTGRES_* to avoid credential drift.
SCRIPT_DB=postgres://postgres:change-me@bloobcat_db:5432/postgres
SCRIPT_DEV=false
SCRIPT_API_URL=https://api.example.com

# Admin
ADMIN_TELEGRAM_ID=123456789
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# Auth (JWT)
AUTH_JWT_SECRET=dev-only-auth-jwt-secret-please-rotate-before-prod-0001
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=86400
AUTH_JWT_LEEWAY_SECONDS=30

# Web auth / OAuth
# Keep feature flags off until migrations, provider redirects and SMTP are configured.
WEB_AUTH_ENABLED=false
PASSWORD_AUTH_ENABLED=false
OAUTH_GOOGLE_ENABLED=false
OAUTH_APPLE_ENABLED=false
OAUTH_YANDEX_ENABLED=false
OAUTH_TELEGRAM_ENABLED=false
OAUTH_PUBLIC_BASE_URL=https://api-app.vectra-pro.net
OAUTH_FRONTEND_APP_URL=https://app.vectra-pro.net
OAUTH_ENABLED_PROVIDERS=google,apple,yandex,telegram
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
# Store multiline private keys in the secret manager; \\n escapes are accepted.
OAUTH_APPLE_PRIVATE_KEY=
# Optional alternative if Apple client secret is generated outside the app.
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
# Telegram Login / OIDC (configure via BotFather Web Login before enabling).
OAUTH_TELEGRAM_CLIENT_ID=
OAUTH_TELEGRAM_CLIENT_SECRET=

# SMTP for password verification and password reset
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Vectra Connect
SMTP_USE_TLS=true

# Resend for password verification and password reset.
# Preferred over SMTP when RESEND_API_KEY and RESEND_FROM_EMAIL are set.
# Do not commit a real API key; set it only in the server/secret environment.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Vectra Connect
RESEND_BASE_URL=https://api.resend.com
RESEND_TIMEOUT_SECONDS=10

# CORS: список разрешённых Origin (домены фронтенда), через запятую.
# Пример: https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=https://app.vectra-pro.net
# CORS: regex для динамических поддоменов (если нужен шаблон вместо списка).
# Пример: ^https:\/\/([a-z0-9-]+\.)?example\.com$
# Emergency mode (temporary): set strict=false and use exact regex ^https://v3018884\.hosted-by-vdsina\.ru$.
# Never use wildcard patterns (.*); temporary override only.
CORS_ALLOW_ORIGIN_REGEX=
# CORS strict allowlist mode (recommended steady-state for production).
# true: разрешение ТОЛЬКО из CORS_ALLOW_ORIGINS, regex игнорируется.
# false: дополнительно разрешать origin по CORS_ALLOW_ORIGIN_REGEX.
# Temporary emergency override: set false only while canonical frontend domain is unavailable,
# then revert to strict allowlist mode (true) after restoration.
CORS_STRICT_ALLOWLIST=true

# Family (optional)
FAMILY_ALERTS_ENABLED=true
# URL вебхука для отправки семейных алертов/уведомлений.
# Если функция не используется — оставь пустым.
FAMILY_ALERTS_WEBHOOK_URL=
FAMILY_ALERTS_WEBHOOK_TIMEOUT_SECONDS=5
FAMILY_ANOMALY_BLOCK_THRESHOLD=3
FAMILY_ANOMALY_BLOCK_WINDOW_HOURS=6
FAMILY_ANOMALY_BLOCK_DURATION_MINUTES=60

# Device-per-user rollout (keep OFF until backend/frontend smoke is green)
DEVICE_PER_USER_ENABLED=false
DEVICE_PER_USER_ENABLED_FOR_NEW_USERS=false
TEMP_SETUP_SITE_PUBLIC_BASE_URL=

# Promo
PROMO_HMAC_SECRET=change-me

# Directus
DIRECTUS_KEY=change-me
DIRECTUS_SECRET=change-me
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me
# Публичный URL Directus (на проде только https, не localhost).
# Пример: https://directus.example.com
DIRECTUS_URL=http://localhost:8055
DIRECTUS_IMPORTED_ADMIN_PASSWORD=change-me
ADMIN_INTEGRATION_URL=http://bloobcat:33083
ADMIN_INTEGRATION_TOKEN=change-me

# Captain User Lookup (optional)
# Секретный API-ключ для серверных интеграций.
# Обязательно: длинный случайный ключ, не "change-me", не коммитить в git.
API_KEY=dev-only-captain-api-key-please-rotate-before-prod-0001
ALLOWLIST_DOMAINS=api.example.com,admin.example.com

# Optional / legacy
ADMIN_USER_MODEL=Admin
ADMIN_SECRET_KEY=change-me
CELERY_BROKER_URL=redis://redis:6379/0

# Fiscalization (optional)
FISCAL_MODE=none
#FISCAL_NPD_INN=
#FISCAL_NPD_PASSWORD=
#FISCAL_NPD_TOKEN=
#FISCAL_TAX_SYSTEM_CODE=1
#FISCAL_VAT_CODE=1
